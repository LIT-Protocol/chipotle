  "components": {
    "schemas": {
      "ApiKeyItem": {
        "description": "One item from list_api_keys (AccountConfig.sol UsageApiKey).",
        "type": "object",
        "required": ["balance", "description", "expiration", "id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "expiration": { "type": "string" },
          "balance": { "type": "integer", "format": "uint64", "minimum": 0.0 }
        }
      },
      "NewAccountResponse": {
        "type": "object",
        "required": ["api_key", "wallet_address"],
        "properties": {
          "api_key": { "type": "string" },
          "wallet_address": { "type": "string" }
        }
      },
      "NewAccountRequest": {
        "type": "object",
        "required": ["account_description", "account_name"],
        "properties": {
          "account_name": { "type": "string" },
          "account_description": { "type": "string" }
        }
      },
      "CreateWalletResponse": {
        "type": "object",
        "required": ["wallet_address"],
        "properties": { "wallet_address": { "type": "string" } }
      },
      "LitActionResponse": {
        "type": "object",
        "required": ["has_error", "logs", "response", "signatures"],
        "properties": {
          "signatures": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LitActionSignature" }
          },
          "response": { "type": "string" },
          "logs": { "type": "string" },
          "has_error": { "type": "boolean" }
        }
      },
      "LitActionSignature": {
        "type": "object",
        "required": ["data", "name"],
        "properties": {
          "name": { "type": "string" },
          "data": { "$ref": "#/components/schemas/SignWithPkpResponse" }
        }
      },
      "SignWithPkpResponse": {
        "type": "object",
        "required": ["pkp_id", "signature", "signed_digest", "signing_scheme"],
        "properties": {
          "signing_scheme": { "type": "string" },
          "signed_digest": { "type": "string" },
          "pkp_id": { "type": "string" },
          "signature": { "type": "string" }
        }
      },
      "LitActionRequest": {
        "description": "API key via header.",
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string" },
          "js_params": { "nullable": true }
        }
      },
      "AccountOpResponse": {
        "description": "Response for account config operations (add_group, add_pkp_to_group, remove_pkp_from_group, add_usage_api_key, remove_usage_api_key).",
        "type": "object",
        "required": ["success"],
        "properties": { "success": { "type": "boolean" } }
      },
      "AddGroupRequest": {
        "description": "Request for add_group. permitted_actions and pkps are keccak256 hashes as hex strings (with or without 0x). API key via header.",
        "type": "object",
        "required": [
          "group_description",
          "group_name",
          "permitted_actions",
          "pkps"
        ],
        "properties": {
          "group_name": {
            "description": "Name of the group (Group.metadata.name in AccountConfig.sol).",
            "type": "string"
          },
          "group_description": {
            "description": "Description of the group (Group.metadata.description in AccountConfig.sol).",
            "type": "string"
          },
          "permitted_actions": {
            "description": "Keccak256 hashes of action IPFS CIDs (hex strings).",
            "type": "array",
            "items": { "type": "string" }
          },
          "pkps": {
            "description": "Keccak256 hashes of PKP/wallet public keys (hex strings).",
            "type": "array",
            "items": { "type": "string" }
          },
          "all_wallets_permitted": {
            "description": "If true, all wallets are permitted to use the group (AccountConfig.sol Group.all_wallets_permitted).",
            "default": false,
            "type": "boolean"
          },
          "all_actions_permitted": {
            "description": "If true, all actions are permitted (AccountConfig.sol Group.all_actions_permitted).",
            "default": false,
            "type": "boolean"
          }
        }
      },
      "AddActionToGroupRequest": {
        "type": "object",
        "required": ["action_ipfs_cid", "group_id"],
        "properties": {
          "group_id": { "type": "string" },
          "action_ipfs_cid": {
            "description": "IPFS CID for the action (will be keccak256-hashed on server).",
            "type": "string"
          },
          "name": {
            "description": "Optional name for the action (stored in contract metadata).",
            "type": "string",
            "nullable": true
          },
          "description": {
            "description": "Optional description for the action (stored in contract metadata).",
            "type": "string",
            "nullable": true
          }
        }
      },
      "AddPkpToGroupRequest": {
        "type": "object",
        "required": ["group_id", "pkp_id"],
        "properties": {
          "group_id": {
            "description": "Group ID (decimal or hex string).",
            "type": "string"
          },
          "pkp_id": { "type": "string" }
        }
      },
      "RemovePkpFromGroupRequest": {
        "type": "object",
        "required": ["group_id", "pkp_id"],
        "properties": {
          "group_id": { "type": "string" },
          "pkp_id": { "type": "string" }
        }
      },
      "AddUsageApiKeyResponse": {
        "description": "Response for account config operations (add_group, add_pkp_to_group, remove_pkp_from_group, add_usage_api_key, remove_usage_api_key).",
        "type": "object",
        "required": ["success", "usage_api_key"],
        "properties": {
          "success": { "type": "boolean" },
          "usage_api_key": { "type": "string" }
        }
      },
      "AddUsageApiKeyRequest": {
        "description": "Request for add_usage_api_key. expiration and balance as decimal strings (e.g. unix timestamp, wei). API key via header.",
        "type": "object",
