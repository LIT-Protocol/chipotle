  "components": {
    "schemas": {
      "ApiKeyItem": {
        "description": "One item from list_api_keys (AccountConfig.sol UsageApiKey).",
        "type": "object",
        "required": [
          "balance",
          "description",
          "expiration",
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "expiration": {
            "type": "string"
          },
          "balance": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
